<launch>
    <include file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
        <!-- <arg name="depth_module.depth_profile" value="1280x720x6" />
        <arg name="rgb_camera.color_profile" value="1920x1080x8" /> -->
        <arg name="enable_sync" value="true" />
        <arg name="align_depth.enable" value="true" />
        <!-- <arg name="temporal_filter.enable" value="true" />
        <arg name="spatial_filter.enable" value="true" />
        <arg name="hole_filling_filter.enable" value="true" />
        <arg name="align_depth.enable" value="true" /> -->
    </include>

    <node pkg="apriltag_ros" exec="apriltag_node" output="screen">
        <remap from="image_rect" to="/camera/camera/color/image_raw" />
        <remap from="camera_info" to="/camera/camera/color/camera_info" />
        <param from="$(find-pkg-share finger_vision)/config/apriltag.yaml" />
    </node>

    <node pkg="finger_vision" exec="vision" output="screen">
        <param from="$(find-pkg-share finger_vision)/config/vision.yaml" />
    </node>

    <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_vision)/config/vision.rviz" on_exit="shutdown"/>
</launch>